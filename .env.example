# The canonical site URL — used for OG metadata's metadataBase. Set this on
# deploy so the og:image and og:url absolute URLs point at the production
# domain instead of the localhost fallback.
NEXT_PUBLIC_SITE_URL=https://declassified.example.com

# Optional. When set, the AI analyst and moderation routes use this key
# server-side and apply a 20/hr per-IP rate limit. When unset, callers must
# supply their own key via the in-browser BYO-key panel; that key is stored
# only in their localStorage and forwarded as an X-Anthropic-Key header.
ANTHROPIC_API_KEY=
